 Software & Data Integrity Failures","permalink":"/niebezpiecznik_szkolenie/docs/labs/a08-integrity-failures"}},{"id":"labs/setup","title":"Lab Setup","description":"Before running any lab, ensure your Kali Linux environment has the required tools installed.","source":"@site/docs/labs/setup.md","sourceDirName":"labs","slug":"/labs/setup","permalink":"/niebezpiecznik_szkolenie/docs/labs/setup","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"title":"Lab Setup","sidebar_position":1},"sidebar":"labsSidebar","next":{"title":"A01 — Broken Access Control","permalink":"/niebezpiecznik_szkolenie/docs/labs/a01-broken-access-control"}},{"id":"theory/burp-suite","title":"Burp Suite — HTTP Interception","description":"Burp Suite is a man-in-the-middle proxy that intercepts and manipulates HTTP/S traffic between your browser and a server, making it the go-to tool for web application security testing.","source":"@site/docs/theory/06-burp-suite.md","sourceDirName":"theory","slug":"/theory/burp-suite","permalink":"/niebezpiecznik_szkolenie/docs/theory/burp-suite","draft":false,"unlisted":false,"tags":[{"inline":true,"label":"tool","permalink":"/niebezpiecznik_szkolenie/docs/tags/tool"},{"inline":true,"label":"proxy","permalink":"/niebezpiecznik_szkolenie/docs/tags/proxy"},{"inline":true,"label":"recon","permalink":"/niebezpiecznik_szkolenie/docs/tags/recon"}],"version":"current","sidebarPosition":7,"frontMatter":{"title":"Burp Suite — HTTP Interception","sidebar_position":7,"tags":["tool","proxy","recon"]},"sidebar":"theorySidebar","previous":{"title":"Privilege Escalation","permalink":"/niebezpiecznik_szkolenie/docs/theory/privilege-escalation"},"next":{"title":"TLS & Certificates","permalink":"/niebezpiecznik_szkolenie/docs/theory/tls-certificates"}},{"id":"theory/cookies-gdpr","title":"Cookies & GDPR","description":"Cookie security attributes protect users from XSS and CSRF attacks, while GDPR mandates that consent for non-essential cookies must be freely given and never pre-ticked.","source":"@site/docs/theory/08-cookies-gdpr.md","sourceDirName":"theory","slug":"/theory/cookies-gdpr","permalink":"/niebezpiecznik_szkolenie/docs/theory/cookies-gdpr","draft":false,"unlisted":false,"tags":[{"inline":true,"label":"cookies","permalink":"/niebezpiecznik_szkolenie/docs/tags/cookies"},{"inline":true,"label":"gdpr","permalink":"/niebezpiecznik_szkolenie/docs/tags/gdpr"},{"inline":true,"label":"defense","permalink":"/niebezpiecznik_szkolenie/docs/tags/defense"}],"version":"current","sidebarPosition":9,"frontMatter":{"title":"Cookies & GDPR","sidebar_position":9,"tags":["cookies","gdpr","defense"]},"sidebar":"theorySidebar","previous":{"title":"TLS & Certificates","permalink":"/niebezpiecznik_szkolenie/docs/theory/tls-certificates"},"next":{"title":".git Exposure — Source Code Leaks","permalink":"/niebezpiecznik_szkolenie/docs/theory/git-exposure"}},{"id":"theory/cryptographic-failures","title":"Cryptographic Failures","description":"Cryptographic Failures (OWASP A02:2021) covers weak algorithms, poor TLS config, insecure password storage, and secrets leaking in code — all of which can expose sensitive data.","source":"@site/docs/theory/13-cryptographic-failures.md","sourceDirName":"theory","slug":"/theory/cryptographic-failures","permalink":"/niebezpiecznik_szkolenie/docs/theory/cryptographic-failures","draft":false,"unlisted":false,"tags":[{"inline":true,"label":"crypto","permalink":"/niebezpiecznik_szkolenie/docs/tags/crypto"},{"inline":true,"label":"attack","permalink":"/niebezpiecznik_szkolenie/docs/tags/attack"},{"inline":true,"label":"owasp-a02","permalink":"/niebezpiecznik_szkolenie/docs/tags/owasp-a-02"}],"version":"current","sidebarPosition":14,"frontMatter":{"title":"Cryptographic Failures","sidebar_position":14,"tags":["crypto","attack","owasp-a02"]},"sidebar":"theorySidebar","previous":{"title":"JWT — JSON Web Token","permalink":"/niebezpiecznik_szkolenie/docs/theory/jwt"},"next":{"title":"HTTP Headers & CF-Connecting-IP Spoofing","permalink":"/niebezpiecznik_szkolenie/docs/theory/http-headers"}},{"id":"theory/csrf","title":"CSRF — Cross-Site Request Forgery","description":"CSRF tricks a logged-in user's browser into sending an authenticated request to a target site without their knowledge, because browsers automatically attach cookies to matching requests.","source":"@site/docs/theory/12-csrf.md","sourceDirName":"theory","slug":"/theory/csrf","permalink":"/niebezpiecznik_szkolenie/docs/theory/csrf","draft":false,"unlisted":false,"tags":[{"inline":true,"label":"csrf","permalink":"/niebezpiecznik_szkolenie/docs/tags/csrf"},{"inline":true,"label":"attack","permalink":"/niebezpiecznik_szkolenie/docs/tags/attack"},{"inline":true,"label":"http","permalink":"/niebezpiecznik_szkolenie/docs/tags/http"}],"version":"current","sidebarPosition":13,"frontMatter":{"title":"CSRF — Cross-Site Request Forgery","sidebar_position":13,"tags":["csrf","attack","http"]},"sidebar":"theorySidebar","previous":{"title":"HTTP Headers & CF-Connecting-IP Spoofing","permalink":"/niebezpiecznik_szkolenie/docs/theory/http-headers"},"next":{"title":"DNS — Domain Squatting & Certificate Transparency","permalink":"/niebezpiecznik_szkolenie/docs/theory/dns-security"}},{"id":"theory/dns-security","title":"DNS — Domain Squatting & Certificate Transparency","description":"Attackers register lookalike domains to impersonate your brand, and Certificate Transparency logs expose subdomains you may not realise are public — both are critical to monitor.","source":"@site/docs/theory/14-dns-security.md","sourceDirName":"theory","slug":"/theory/dns-security","permalink":"/niebezpiecznik_szkolenie/docs/theory/dns-security","draft":false,"unlisted":false,"tags":[{"inline":true,"label":"dns","permalink":"/niebezpiecznik_szkolenie/docs/tags/dns"},{"inline":true,"label":"recon","permalink":"/niebezpiecznik_szkolenie/docs/tags/recon"},{"inline":true,"label":"defense","permalink":"/niebezpiecznik_szkolenie/docs/tags/defense"}],"version":"current","sidebarPosition":15,"frontMatter":{"title":"DNS — Domain Squatting & Certificate Transparency","sidebar_position":15,"tags":["dns","recon","defense"]},"sidebar":"theorySidebar","previous":{"title":"CSRF — Cross-Site Request Forgery","permalink":"/niebezpiecznik_szkolenie/docs/theory/csrf"},"next":{"title":"IoT, Smart Devices & Zero-day","permalink":"/niebezpiecznik_szkolenie/docs/theory/iot-zero-day"}},{"id":"theory/endpoints","title":"Endpoint Discovery","description":"Endpoint discovery is the practice of finding hidden API endpoints and admin panels by guessing URL patterns — and it matters because exposed hidden paths can give attackers direct access to sensitive functionality.","source":"@site/docs/theory/05-endpoints.md","sourceDirName":"theory","slug":"/theory/endpoints","permalink":"/niebezpiecznik_szkolenie/docs/theory/endpoints","draft":false,"unlisted":false,"tags":[{"inline":true,"label":"recon","permalink":"/niebezpiecznik_szkolenie/docs/tags/recon"},{"inline":true,"label":"owasp-a01","permalink":"/niebezpiecznik_szkolenie/docs/tags/owasp-a-01"}],"version":"current","sidebarPosition":6,"frontMatter":{"title":"Endpoint Discovery","sidebar_position":6,"tags":["recon","owasp-a01"]},"sidebar":"theorySidebar","previous":{"title":"Reconnaissance","permalink":"/niebezpiecznik_szkolenie/docs/theory/recon"},"next":{"title":"IDOR (Insecure Direct Object Reference)","permalink":"/niebezpiecznik_szkolenie/docs/theory/idor"}},{"id":"theory/git-exposure","title":".git Exposure — Source Code Leaks","description":"An exposed .git/ directory on a web server lets attackers reconstruct the entire source code of an application — including secrets and API keys from the full commit history.","source":"@site/docs/theory/09-git-exposure.md","sourceDirName":"theory","slug":"/theory/git-exposure","permalink":"/niebezpiecznik_szkolenie/docs/theory/git-exposure","draft":false,"unlisted":false,"tags":[{"inline":true,"label":"recon","permalink":"/niebezpiecznik_szkolenie/docs/tags/recon"},{"inline":true,"label":"attack","permalink":"/niebezpiecznik_szkolenie/docs/tags/attack"},{"inline":true,"label":"source-code","permalink":"/niebezpiecznik_szkolenie/docs/tags/source-code"}],"version":"current","sidebarPosition":10,"frontMatter":{"title":".git Exposure — Source Code Leaks","sidebar_position":10,"tags":["recon","attack","source-code"]},"sidebar":"theorySidebar","previous":{"title":"Cookies & GDPR","permalink":"/niebezpiecznik_szkolenie/docs/theory/cookies-gdpr"},"next":{"title":"JWT — JSON Web Token","permalink":"/niebezpiecznik_szkolenie/docs/theory/jwt"}},{"id":"theory/http-headers","title":"HTTP Headers & CF-Connecting-IP Spoofing","description":"If a server blindly trusts IP headers like CF-Connecting-IP or X-Forwarded-For without verifying the request actually came through Cloudflare, attackers can spoof any IP address.","source":"@site/docs/theory/11-http-headers.md","sourceDirName":"theory","slug":"/theory/http-headers","permalink":"/niebezpiecznik_szkolenie/docs/theory/http-headers","draft":false,"unlisted":false,"tags":[{"inline":true,"label":"http","permalink":"/niebezpiecznik_szkolenie/docs/tags/http"},{"inline":true,"label":"headers","permalink":"/niebezpiecznik_szkolenie/docs/tags/headers"},{"inline":true,"label":"spoofing","permalink":"/niebezpiecznik_szkolenie/docs/tags/spoofing"},{"inline":true,"label":"attack","permalink":"/niebezpiecznik_szkolenie/docs/tags/attack"}],"version":"current","sidebarPosition":12,"frontMatter":{"title":"HTTP Headers & CF-Connecting-IP Spoofing","sidebar_position":12,"tags":["http","headers","spoofing","attack"]},"sidebar":"theorySidebar","previous":{"title":"Cryptographic Failures","permalink":"/niebezpiecznik_szkolenie/docs/theory/cryptographic-failures"},"next":{"title":"CSRF — Cross-Site Request Forgery","permalink":"/niebezpiecznik_szkolenie/docs/theory/csrf"}},{"id":"theory/idor","title":"IDOR (Insecure Direct Object Reference)","description":"IDOR le